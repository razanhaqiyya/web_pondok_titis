{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/user.html"
    },
    {
      "source": "/(css|js|images)/(.*)",
      "destination": "/frontend/$1/$2"
    },
    {
      "source": "/admin",
      "destination": "/frontend/admin.html"
    },
    {
      "source": "/admin.html",
      "destination": "/frontend/admin.html"
    },
    {
      "source": "/user",
      "destination": "/frontend/user.html"
    },
    {
      "source": "/user.html",
      "destination": "/frontend/user.html"
    },
    {
      "source": "/payments",
      "destination": "/frontend/payments.html"
    },
    {
      "source": "/payments.html",
      "destination": "/frontend/payments.html"
    },
    {
      "source": "/reports",
      "destination": "/frontend/reports.html"
    },
    {
      "source": "/reports.html",
      "destination": "/frontend/reports.html"
    },
    {
      "source": "/room-management",
      "destination": "/frontend/room-management.html"
    },
    {
      "source": "/room-management.html",
      "destination": "/frontend/room-management.html"
    },
    {
      "source": "/settings",
      "destination": "/frontend/settings.html"
    },
    {
      "source": "/settings.html",
      "destination": "/frontend/settings.html"
    },
    {
      "source": "/tenant-data",
      "destination": "/frontend/tenant-data.html"
    },
    {
      "source": "/tenant-data.html",
      "destination": "/frontend/tenant-data.html"
    }
  ]
}