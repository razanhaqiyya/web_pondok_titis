# Windows 11 - inventory Ansible
# Semua VM pakai key yang sudah di-copy ke /home/vagrant/ dengan chmod 600

[database]
vm-database ansible_host=192.168.56.11 ansible_ssh_private_key_file=/home/vagrant/insecure_private_key

[backend]
vm-backend ansible_host=192.168.56.10 ansible_ssh_private_key_file=/home/vagrant/insecure_private_key

[frontend]
vm-frontend ansible_host=192.168.56.12 ansible_ssh_private_key_file=/home/vagrant/insecure_private_key

[all:vars]
ansible_user=vagrant
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
ansible_python_interpreter=/usr/bin/python3
